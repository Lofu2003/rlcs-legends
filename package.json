{
  "name": "rlcs-legends",
  "version": "0.1.0",
  "description": "RLCS Legends — Draft-Manager-Spiel, abgeleitet von draftrlcs.app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.lofu2003.rlcslegends",
    "productName": "RLCS Legends",
    "files": [
      "**/*",
      "!*.md"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": {
      "provider": "github",
      "owner": "Lofu2003",
      "repo": "rlcs-legends"
    }
  }
}
